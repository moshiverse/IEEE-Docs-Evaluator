SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:<port>/<database>
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>
SPRING_JPA_SHOW_SQL=false

# Comma-separated allowed origins (Vercel + optional local dev)
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Google service account credential (provide ONE of these)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Spreadsheet and provider metadata
GOOGLE_SHEET_ID=<spreadsheet-id>
OPENROUTER_HTTP_REFERER=https://your-frontend.vercel.app
OPENROUTER_APP_TITLE=IEEE Docs Evaluator
